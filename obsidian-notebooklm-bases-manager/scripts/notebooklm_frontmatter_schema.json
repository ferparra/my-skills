{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NotebookLM note frontmatter",
  "type": "object",
  "required": [
    "type",
    "tags",
    "connection_strength",
    "potential_links",
    "notebooklm_note_kind"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["note", "resource", "moc", "guide"]
    },
    "para_type": {
      "type": "string",
      "enum": ["area", "project", "resource"]
    },
    "tags": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ]
    },
    "connection_strength": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "potential_links": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^\\[\\[[^\\]]+\\]\\]$"
      }
    },
    "notebooklm_note_kind": {
      "type": "string",
      "enum": ["index", "map", "notebook"]
    },
    "notebooklm_title": {
      "type": "string",
      "minLength": 1
    },
    "notebooklm_url": {
      "type": "string",
      "pattern": "^https://notebooklm\\.google\\.com/notebook/[a-z0-9-]+$"
    },
    "notebooklm_lane": {
      "type": "string",
      "enum": [
        "ai-systems",
        "strategic-judgment",
        "philosophy-meaning",
        "health-resilience",
        "pkm-operations",
        "unassigned"
      ]
    },
    "notebooklm_source_note": {
      "type": "string",
      "pattern": "^\\[\\[[^\\]]+\\]\\]$"
    },
    "notebooklm_professional_track": {
      "type": "boolean"
    },
    "notebooklm_life_track": {
      "type": "boolean"
    },
    "notebooklm_review_due": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "notebooklm_note_kind": {
            "const": "notebook"
          }
        }
      },
      "then": {
        "required": [
          "notebooklm_title",
          "notebooklm_url",
          "notebooklm_lane"
        ]
      }
    }
  ]
}
